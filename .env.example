# Google Gemini API Key (Optional - will use fallback templates if not provided)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# External RabbitMQ broker
# Deploy RabbitMQ separately, then use its hostname here instead of localhost.
RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USER=
RABBITMQ_PASS=
